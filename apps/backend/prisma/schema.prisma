generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DashboardTemplate {
  RESTAURANTE
  COZINHA
  FINANCEIRO
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  password  String
  role      String      @default("USER")
  template  DashboardTemplate @default(RESTAURANTE)
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  gestoras     Gestora[]
  unidades     Unidade[]
  categorias   Categoria[]
  transacoes   Transacao[]
  dashboards   Dashboard[]       @relation("DashboardOwner")
  dashboardAccess DashboardAccess[]
}

model Gestora {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unidades Unidade[]

  @@unique([userId, name])
}

model Dashboard {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String?
  ownerId     String
  template    DashboardTemplate @default(RESTAURANTE)
  owner       User              @relation("DashboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  isDefault   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  access      DashboardAccess[]
}

model DashboardAccess {
  id          String      @id @default(uuid())
  dashboardId String
  dashboard   Dashboard   @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  String      @default("VIEW")
  createdAt   DateTime    @default(now())

  @@unique([dashboardId, userId])
}

model Unidade {
  id        String      @id @default(uuid())
  name      String
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gestoraId String?
  gestora   Gestora?    @relation(fields: [gestoraId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  transacoes Transacao[]

  @@unique([userId, name])
}

model Categoria {
  id        String      @id @default(uuid())
  name      String
  type      String      // "RECEITA" ou "DESPESA"
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  transacoes Transacao[]
}

model Transacao {
  id          String      @id @default(uuid())
  description String
  gestora     String?
  amount      Float
  date        DateTime    @default(now())
  type        String      // "RECEITA" ou "DESPESA"
  qtdFunc     Int?        // Quantidade de funcionários no mês
  
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  unidadeId   String
  unidade     Unidade     @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  categoriaId String
  categoria   Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
