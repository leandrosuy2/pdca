# Onde o Next (servidor) encaminha /api/* → Nest. Mesmo host: padrão abaixo. Docker/Easypanel com dois
# serviços: ex. API_INTERNAL_URL=http://nome-do-container-api:3001
API_INTERNAL_URL=http://127.0.0.1:3001

# Só use se a API for outro host público (aí o browser chama direto, sem /api):
# NEXT_PUBLIC_API_URL=https://api.exemplo.com
