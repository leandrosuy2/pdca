# --- Produção HTTPS (Easypanel, domínio próprio, só 443 público) ---
# Defina a URL **pública** do serviço Nest (a que o painel mostra para a API), depois rebuild do Next:
# NEXT_PUBLIC_API_URL=https://SEU-SERVICO-API.hlz1f3.easypanel.host
#
# Front em https://pdca.vvrefeicoes.com.br sem porta 3001 exposta → NÃO deixe só o fallback "mesmo host:3001".

# --- Mesmo servidor com portas abertas (HTTP / IP) ---
# Deixe NEXT_PUBLIC_API_URL vazio: o browser usa mesmo hostname + porta abaixo.

NEXT_PUBLIC_API_PORT=3001
