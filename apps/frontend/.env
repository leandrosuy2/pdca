# Em produção (mesmo servidor, IP ou domínio): deixe NEXT_PUBLIC_API_URL vazio ou comentado —
# o front usa automaticamente o mesmo host do navegador + NEXT_PUBLIC_API_PORT (API Nest).
# Ex.: abrir http://SEU_IP:3000 → chama API em http://SEU_IP:3001
#
# Só preencha NEXT_PUBLIC_API_URL se a API estiver em outro host (ex.: https://api.empresa.com):
# NEXT_PUBLIC_API_URL=https://api.empresa.com

NEXT_PUBLIC_API_PORT=3001
