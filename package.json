{
  "name": "pdca",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "start:api": "npm run build -w @pdca/api && npm run start -w @pdca/api",
    "start:web": "npm run build -w @pdca/web && npm run start -w @pdca/web",
    "lint": "turbo run lint",
    "db:generate": "npm run prisma:generate -w @pdca/api",
    "db:migrate": "npm run prisma:migrate -w @pdca/api",
    "db:seed": "npm run prisma:seed -w @pdca/api",
    "db:studio": "npm run prisma:studio -w @pdca/api"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
